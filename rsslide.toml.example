# Example rsslide.toml. Drop this file next to your YAML (renamed to
# `rsslide.toml`), or pass it with `--config path.toml`. Every section is
# optional; missing fields keep the built-in defaults.

[slide]
width_mm = 254.0
height_mm = 143.0
margin_x_mm = 8.0
margin_top_mm = 10.0
page_bottom_reserved_mm = 6.0

[title]
font_size_pt = 28.0
rule_offset_mm = 9.0
content_gap_mm = 4.0

[body]
font_size_pt = 18.0
line_height_mm = 9.0
section_gap_mm = 5.0

[code]
font_size_pt = 12.0
line_height_mm = 6.5
padding_mm = 4.0
icon_size_mm = 16.0
icon_inset_mm = 2.0

[svg]
filter_scale = 2.0
flatten_css_vars = true
top_gap_mm = 4.0       # extra gap above the SVG
margin_x_mm = 4.0      # side margin for SVGs (smaller = bigger SVG)

[fonts]
title = "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"
body  = "/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"
code  = "/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf"

[colors]
text            = "#000000"
bullet          = "#000000"
title_rule      = "#000000"
code_background = "#f0f0f0"
